                onMouseLeave={e => { (e.currentTarget as HTMLElement).style.transform = 'scale(1)'; }}
                onMouseDown={e => { if (!disabled) { uiAudio.playClick(); (e.currentTarget as HTMLElement).style.transform = 'scale(0.97)'; } }}
