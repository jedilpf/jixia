const NETWORK_CONFIG = {
  serverUrl: 'ws://localhost:8080',
  reconnectInterval: 3000,      // 重连间隔: 3秒
  maxReconnectAttempts: 5,      // 最大重连次数: 5
  heartbeatInterval: 5000,      // 心跳间隔: 5秒
  maxLatency: 200,              // 最大延迟: 200ms
};
```

### AI配置

