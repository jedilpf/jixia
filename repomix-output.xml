  name: string;
  description: string;
  type: EventType;
  status: EventStatus;
  startTime: number;
  endTime: number;
  bannerImage?: string;
  icon?: string;
  rewards: EventReward[];
  tasks: EventTask[];
  rules: string[];
  isFeatured: boolean;
  priority: number;
  metadata?: Record<string, unknown>;
}

export interface EventReward {
  id: string;
  name: string;
  description: string;
  type: "gold" | "gems" | "card_pack" | "card" | "cosmetic" | "title" | "border";
  quantity: number;
  itemId?: string;
