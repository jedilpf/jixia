      cardId: card.id,
      name: card.name,
      atk: minionCard.atk,
      hp: minionCard.hp,
      maxHp: minionCard.hp,
      canAttack: true,
      hasAttacked: false,
      isExhausted: !minionCard.hasCharge,
      hasTaunt: minionCard.hasTaunt,
      rarity: minionCard.rarity,
    };

