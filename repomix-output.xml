    atk: number;
    hp: number;
    maxHp: number;
    canAttack: boolean;
    hasAttacked: boolean;
    isExhausted: boolean;
    gear: GearInstance | null;
    buffs: Buffs;
    debuffs: Debuffs;
    status: CardStatus[];
    rarity: RarityZh;
    hasTaunt?: boolean;
    hasCharge?: boolean;
    hasDivineShield?: boolean;
    hasStealth?: boolean;
