// 文件：src/hooks/useBattleState.ts（续）
// 功能：战斗状态管理 Hook - 结束回合和 AI 逻辑

  const handleEndTurn = useCallback((
    executeEnemyPlayCardWithAnimation: (
      card: { name: string; type: string },
      boardIndex: number,
      onComplete: () => void
    ) => void,
    executeEnemyAttackWithAnimation: (
      attackerType: 'minion' | 'hero',
      attackerIndex: number | null,
      targetType: 'minion' | 'hero',
      targetIndex: number | null,
      onComplete: () => void
    ) => void
  ) => {
    if (game.currentPlayer !== 'player' || game.winner) return;

    let newGame = endTurn(game);
    setGame(newGame);
    setSelection({ type: 'none' });

    setTimeout(() => {
      newGame = startTurn(newGame, 'enemy');
      setGame(newGame);

      const aiAct = () => {
        const action = getEnemyAction(newGame);
        if (!action || action.type === 'end_turn') {
          newGame = endTurn(newGame);
          newGame = startTurn(newGame, 'player');
          setGame(newGame);
          return;
        }

        if (action.type === 'hero_power') {
          const result = activateHeroPower(newGame, 'enemy');
          if (result) {
            newGame = result;
            setGame({ ...newGame });
          }
          setTimeout(aiAct, 800);
        } else if (action.type === 'play_card' && action.data) {
          const card = newGame.enemy.hand[action.data.handIndex];
          if (card) {
            executeEnemyPlayCardWithAnimation(
              card,
              action.data.boardIndex,
              () => {
                const result = playCard(
                  newGame,
                  'enemy',
                  action.data.handIndex,
                  action.data.boardIndex
                );
                if (result) {
                  newGame = result;
                  setGame({ ...newGame });
                }
                setTimeout(aiAct, 500);
              }
            );
          }
        }
      };

      setTimeout(aiAct, 500);
    }, 500);
  }, [game]);

