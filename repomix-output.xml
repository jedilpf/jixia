        ) : null}
        {phase === 'ming_bian' && enemyMainPlanned ? (
          <span className="rounded border border-[#b57878]/50 bg-[#b57878]/12 px-1.5 py-0.5 text-[9px] text-[#8a4f4f]">
            鏁屾柟鏄庤
          </span>
        ) : null}
        {phase === 'an_mou' && playerSecretPlanned ? (
          <span className="rounded border border-[#c9952a]/50 bg-[#c9952a]/15 px-1.5 py-0.5 text-[9px] text-[#8c6626]">
            鎴戞柟鏆楃瓥
          </span>
        ) : null}
        {phase === 'an_mou' ? (
          <span className="rounded border border-[#bfa884]/35 bg-[#f7edde]/40 px-1.5 py-0.5 text-[9px] text-[#9a886a]">
            鏁屾柟鏆楃瓥鏈煡
          </span>
        ) : null}
      </div>
      {/* Enemy units */}
      <div className="flex flex-col gap-1 items-center">
        <MiniUnitPip unit={enemyLane.back} isEnemy label="鏁屽悗" />
        <MiniUnitPip unit={enemyLane.front} isEnemy label="鏁屽墠" />
