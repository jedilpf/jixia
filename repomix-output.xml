import { ARENAS } from '@/battleV2/arena';
import { ArenaId } from '@/battleV2/types';

interface BattleSetupProps {
  selectedArenaId: ArenaId;
  onSelectArena: (arenaId: ArenaId) => void;
  onStartBattle: () => void;
  onBackMenu: () => void;
