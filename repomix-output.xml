      {/* 敌方英雄 */}
      <HeroCard
        hero={enemyHero}
        side="enemy"
        x={100}
        y={200}
      />
      
      {/* 我方前排 */}
      <BoardRow
        side="player"
        row="front"
        slots={playerBoard.front}
        y={BOARD_CONFIG.playerFrontY}
        startX={BOARD_CONFIG.startX}
        slotWidth={BOARD_CONFIG.slotWidth}
        slotGap={BOARD_CONFIG.slotGap}
      />
      
      {/* 我方后排 */}
      <BoardRow
        side="player"
        row="back"
        slots={playerBoard.back}
        y={BOARD_CONFIG.playerBackY}
        startX={BOARD_CONFIG.startX}
        slotWidth={BOARD_CONFIG.slotWidth}
        slotGap={BOARD_CONFIG.slotGap}
