export function HandCard({
  card,
  index,
  x,
  y,
  rotation,
  zIndex,
  isPlayable,
  isEnemy = false,
  isSelected = false,
  isDragging = false,
  scale,
  onPointerDown,
}: HandCardProps) {
  const [isHovered, setIsHovered] = useState(false);
  const rarity = card.rarity ?? 'common';
  const W = 238 * scale;
  const H = 333 * scale;

  const borderColor = isSelected
    ? '#fff'
    : isPlayable
      ? '#E85D04'
      : RARITY_BORDER[rarity];

  const glowShadow = isSelected
    ? `0 0 0 3px #fff, 0 0 20px rgba(255,255,255,0.5)`
    : isHovered
      ? `0 0 0 2px ${RARITY_BORDER[rarity]}, 0 0 24px rgba(232,93,4,0.5), 
        0 8px 30px rgba(0,0,0,0.7)`
      : isPlayable
        ? `0 0 0 2px rgba(232,93,4,0.9), 0 0 18px rgba(232,93,4,0.6)`
        : `0 4px 16px rgba(0,0,0,0.6)`;

  const hoverActive = isHovered && !isDragging && !isEnemy;
  const computedTransform = isDragging
    ? 'rotate(0deg)'
    : hoverActive
      ? `rotate(0deg) scale(1.5) translateY(-${100 * scale}px)`
      : `rotate(${rotation}deg)`;
  const computedZ = isDragging ? 9999 : hoverActive ? 5000 : zIndex;

