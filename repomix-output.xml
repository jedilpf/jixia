        <button
          onClick={onOpenChat}
          className="group w-9 h-9 rounded-lg bg-[#2a2318]/80 border border-[#5c4d3a]/50 flex items-center justify-center text-[#b8a88a] hover:bg-[#3d3225] hover:border-[#7ab8c9]/50 hover:text-[#7ab8c9] transition-all"
          title="消息"
