    >
      <line
        x1={startX * scale}
        y1={startY * scale}
        x2={currentX * scale}
        y2={currentY * scale}
        stroke="#E85D04"
        strokeWidth={3 * scale}
        strokeLinecap="round"
        opacity={0.8}
      />
      <circle
        cx={currentX * scale}
        cy={currentY * scale}
        r={8 * scale}
        fill="#E85D04"
        opacity={0.9}
      />
