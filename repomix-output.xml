                    width: '100%', height: '100%',
                    background: disabled
                        ? 'linear-gradient(180deg, #2a2018 0%, #1a1410 100%)'
                        : 'linear-gradient(180deg, #7c3a00 0%, #4a1a00 60%, #2e1000 100%)',
                    border: `${scale * 1.5}px solid ${disabled ? 'rgba(100,80,60,0.4)' : 'rgba(232,93,4,0.7)'}`,
