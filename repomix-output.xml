  hasMainCard: boolean;
  hasResponseCard: boolean;
  hasSecretCard: boolean;
  mainTargetSeat: SeatId;
  secretTargetSeat: SeatId;
  lockedPublic: boolean;
  lockedSecret: boolean;
  handCount: number;
  writingCount: number;
}

export interface RevealInfo {
