// 文件：src/utils/gameLogic.ts（续）
// 功能：游戏核心逻辑 - 英雄攻击判断

export function canHeroAttack(hero: { weapon: WeaponInstance | null; 
  hasAttackedThisTurn: boolean }): boolean {
  return hero.weapon !== null && hero.weapon.durability > 0 && 
    !hero.hasAttackedThisTurn;
}

export function heroAttack(
  game: GameState,
  attackerPlayerId: PlayerId,
  targetPlayerId: PlayerId,
  targetIndex: number | 'hero'
): GameState | null {
  const newGame = deepCopyGame(game);
  const attackerPlayer = attackerPlayerId === 'player' ? newGame.player : newGame.enemy;
  const targetPlayer = targetPlayerId === 'player' ? newGame.player : newGame.enemy;

  if (!canHeroAttack(attackerPlayer.hero)) return null;

  const weapon = attackerPlayer.hero.weapon!;
  let logAction = '';

  if (targetIndex === 'hero') {
    const damage = weapon.atk;
    const actualDamage = Math.max(0, damage - targetPlayer.hero.armor);
    targetPlayer.hero.armor = Math.max(0, targetPlayer.hero.armor - damage);
    targetPlayer.hero.hp -= actualDamage;
    logAction = `英雄使用 ${weapon.name} 攻击敌方英雄，造成 ${actualDamage} 点伤害`;

--------------------------------------------------------------------------------
                              第 20 页
--------------------------------------------------------------------------------

// 文件：src/utils/gameLogic.ts（续）
// 功能：游戏核心逻辑 - 英雄攻击随从

  } else {
    const target = targetPlayer.board[targetIndex];
    if (!target) return null;

    if (target.divineShieldActive) {
      target.divineShieldActive = false;
      logAction = `英雄攻击 ${target.name}，圣盾抵挡了伤害`;
    } else {
      target.hp -= weapon.atk;
    }

    const heroIncoming = target.atk;
    const heroActualDamage = Math.max(0, heroIncoming - attackerPlayer.hero.armor);
    attackerPlayer.hero.armor = Math.max(0, attackerPlayer.hero.armor - heroIncoming);
    attackerPlayer.hero.hp -= heroActualDamage;

