export function createCharacterInstance(
    cardId: string,
    name: string,
    atk: number,
    hp: number,
    rarity: RarityZh,
    options?: {
        hasTaunt?: boolean;
        hasCharge?: boolean;
        hasDivineShield?: boolean;
        hasStealth?: boolean;
        skillDesc?: string;
        keywords?: Keyword[];
    }
): CharacterInstance {
