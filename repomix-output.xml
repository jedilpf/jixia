    ├── layers/                # 三层架构
    ├── panels/                # 面板
    ├── animations/            # 动画
    └── pixi/                  # PixiJS
```

**问题5：数据类型分散**
- `src/data/cards.ts`
- `src/data/showcaseCards.ts`
- `src/data/game/cards.ts`
- `src/battleV2/cards.ts`
