      isDragging: false,
      cardId: null,
      handIndex: null,
      currentX: 0,
      currentY: 0,
      startX: 0,
      startY: 0,
    });
  }, []);

  return {
    dragState,
    handleDragStart,
    handleDragMove,
    handleDragEnd,
  };
}

