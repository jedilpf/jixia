  playerRank?: LeaderboardEntry;
}

export type LeaderboardType =
  | "ranked"
  | "win_rate"
  | "wins"
  | "play_time"
  | "achievements"
  | "weekly"
  | "monthly";

export interface RankTier {
  name: string;
  minScore: number;
  maxScore: number;
  icon: string;
  color: string;
  rewards: {
    gold: number;
    gems: number;
    cardPacks: number;
  };
}

export const RANK_TIERS: RankTier[] = [
  {
    name: "青铜",
