  BattleArena,
  BottomControls,
  CardLibraryPanel,
  StatusPanel,
  LogDrawer,
  ChatFloat,
  OperationHints,
  LogButton,
  ExitConfirmModal,
} from './battle';

// 所有可用卡牌（用于图鉴）
import { TEST_CARDS_V01 } from '@/battleV2/testCards';

// ═══════════════════════════════════════════════════════════════
// Props
// ═══════════════════════════════════════════════════════════════

interface BattleFrameV2Props {
