      y: (clientY - scaleInfo.offsetY) / scaleInfo.scale,
    }),
    [scaleInfo]
  );

  const canvasToScreen = useCallback(
    (x: number, y: number) => ({
      x: x * scaleInfo.scale + scaleInfo.offsetX,
      y: y * scaleInfo.scale + scaleInfo.offsetY,
    }),
    [scaleInfo]
  );

  return {
    scaleInfo,
    screenToCanvas,
    canvasToScreen,
  };
}

