    phase: (playerId === 'player' ? 'player_turn' : 'enemy_turn') as GamePhase,
    currentPlayer: playerId,
    log: [...newGame.log, createLogEntry(newGame.turnNumber, playerId, 
      `回合开始，法力水晶 ${player.mana}/${player.maxMana}`)],
