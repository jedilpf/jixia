      >
        <img src={artSrc(card)} alt={card.name} className="h-full w-full object-cover" />
        <div className="absolute inset-0 bg-gradient-to-t from-[#12100a]/85 via-[#12100a]/15 to-transparent" />
      </div>

      {/* ── 类型边框图片叠加层（允许向外扩出） ── */}
