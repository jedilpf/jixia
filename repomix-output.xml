      {/* 费用圆圈 */}
      <div
        className="absolute left-2.5 top-2.5 flex h-9 w-9 items-center justify-center rounded-full text-[16px] font-bold text-[#f0c97a]"
        style={{ 
          background: 'rgba(18,16,10,0.85)', 
          zIndex: 30, 
          border: `2px solid ${frame.color}`,
