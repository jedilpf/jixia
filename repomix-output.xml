export function canAttack(minion: MinionInstance): boolean {
  return minion.canAttack && !minion.hasAttacked && !minion.isExhausted && 
    minion.atk > 0;
}

export function performAttack(
  game: GameState,
  attackerPlayerId: PlayerId,
  attackerIndex: number,
  targetPlayerId: PlayerId,
  targetIndex: number | 'hero'
): GameState | null {
  const newGame = deepCopyGame(game);
  const attackerPlayer = attackerPlayerId === 'player' ? newGame.player : newGame.enemy;
  const targetPlayer = targetPlayerId === 'player' ? newGame.player : newGame.enemy;
  const attacker = attackerPlayer.board[attackerIndex];

  if (!attacker || !canAttack(attacker)) return null;

  let logAction = '';

  if (targetIndex === 'hero') {
    const damage = attacker.atk;
    const heroActual = Math.max(0, damage - targetPlayer.hero.armor);
    targetPlayer.hero.armor = Math.max(0, targetPlayer.hero.armor - damage);
    targetPlayer.hero.hp -= heroActual;
    attacker.hasAttacked = true;
    logAction = `${attacker.name} 攻击英雄，造成 ${heroActual} 点伤害`;
  }

