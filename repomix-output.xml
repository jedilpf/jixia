function getRarityBorderColor(rarity?: string): string {
  const colors: Record<string, string> = {
    common: 'rgba(139,115,85,0.7)',
    rare: 'rgba(30,120,230,0.85)',
    epic: 'rgba(160,60,220,0.85)',
    legendary: 'rgba(255,170,0,0.95)',
  };
  return colors[rarity ?? 'common'];
}

function getRarityGradient(rarity?: string): string {
  const gradients: Record<string, string> = {
    common: 'linear-gradient(160deg, #252015 0%, #1a1508 100%)',
    rare: 'linear-gradient(160deg, #101830 0%, #0a1020 100%)',
    epic: 'linear-gradient(160deg, #1e0830 0%, #120520 100%)',
    legendary: 'linear-gradient(160deg, #2a1800 0%, #1a0e00 100%)',
  };
  return gradients[rarity ?? 'common'];
}

