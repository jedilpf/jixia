// 鈹€鈹€鈹€ FanHand 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€

function FanHand({
  cards,
  selectedCardId,
  onSelect,
  onDragStart,
}: {
  cards: DebateCard[];
  selectedCardId: string | null;
  onSelect: (id: string) => void;
  onDragStart?: (cardId: string) => void;
}) {
  const n = cards.length;
  const maxSpreadDeg = 18;
  const overlapPx = 46;

  return (
    <div
      className="flex items-end justify-center"
      style={{ paddingTop: 28, paddingBottom: 18, paddingLeft: 28, paddingRight: 20 }}
    >
      {cards.map((card, i) => {
        const t = n <= 1 ? 0 : (i / (n - 1)) * 2 - 1;
        const angle = t * maxSpreadDeg;
        const liftY = (1 - t * t) * 12;
        const isSelected = selectedCardId === card.id;
        return (
          <button
            type="button"
            key={card.id}
            draggable={true}
            onDragStart={(e) => {
              e.dataTransfer.setData('text/plain', card.id);
              if (onDragStart) onDragStart(card.id);
            }}
            onMouseDown={(e) => {
              e.stopPropagation();
              onSelect(card.id);
            }}
            onClick={(e) => {
              e.preventDefault();
              e.stopPropagation();
            }}
            style={{
              marginLeft: i === 0 ? 0 : -overlapPx,
              transform: `rotate(${angle}deg) translateY(${isSelected ? -36 : liftY}px) scale(${isSelected ? 1.08 : 1})`,
              transformOrigin: 'bottom center',
              zIndex: isSelected ? 100 : 10 + i,
              position: 'relative',
              cursor: 'grab',
              transition: 'transform 0.2s ease, z-index 0.15s ease',
              background: 'transparent',
              border: 'none',
              padding: 0,
            }}
          >
            <HandCard card={card} isSelected={isSelected} />
          </button>
        );
      })}
    </div>
  );
}

