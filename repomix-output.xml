          atk: heroPower.value,
          hp: 1,
          maxHp: 1,
          canAttack: true,
          hasAttacked: false,
          isExhausted: true,
        };
        player.board[emptySlot] = minion;
        logAction += `，召唤 1/1 报告兵`;
      } else {
        logAction += `，但战场已满`;
      }
      break;
    }

