                <BronzeGear x={W * 0.5 - 30 * scale} y={H * 0.42} size={60 * scale} speed={12} opacity={0.08} reverse />
            </svg>

            {/* ── 层6：战场分割线系统 ── */}
            <div style={{ position: 'absolute', top: `${midY}px`, left: 0, right: 0 }}>
                {/* 主分割线 */}
                <div style={{
