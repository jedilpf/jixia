// 文件：src/hooks/useDragAndDrop.ts（续）
// 功能：拖拽功能 Hook - 拖拽移动和结束

  const handleDragMove = useCallback(
    (
      e: PointerEvent,
      screenToCanvas: (x: number, y: number) => { x: number; y: number }
    ) => {
      if (!dragState.isDragging) return;

      const pos = screenToCanvas(e.clientX, e.clientY);
      setDragState((prev) => ({
        ...prev,
        currentX: pos.x,
        currentY: pos.y,
      }));
    },
    [dragState.isDragging]
  );

  const handleDragEnd = useCallback(() => {
    setDragState({
      isDragging: false,
      cardId: null,
      handIndex: null,
      currentX: 0,
      currentY: 0,
      startX: 0,
      startY: 0,
    });
  }, []);

  return {
    dragState,
    handleDragStart,
    handleDragMove,
    handleDragEnd,
  };
}

