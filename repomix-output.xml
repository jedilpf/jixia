      if (match) {
        targetSlot = parseInt(match[1]);
      }
    }

    if (targetSlot === null) {
      const placementPriority = [3, 2, 4, 1, 5, 0, 6];
      for (const slotIndex of placementPriority) {
        if (game.player.board[slotIndex] === null) {
          targetSlot = slotIndex;
          break;
        }
      }
    }

    if (targetSlot !== null && targetSlot !== -1) {
      const result = playCard(game, 'player', castingState.handIndex, targetSlot);
      if (result) {
        setGame(result);
      }
    }

    setCastingState({
