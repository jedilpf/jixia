import { useState, useCallback } from 'react';
import { DragState } from '@/types/game';

export function useDragAndDrop() {
  const [dragState, setDragState] = useState<DragState>({
    isDragging: false,
    cardId: null,
    handIndex: null,
    currentX: 0,
    currentY: 0,
    startX: 0,
    startY: 0,
  });

  const handleDragStart = useCallback(
    (e: React.PointerEvent, cardId: string, handIndex: number, 
      screenToCanvas: (x: number, y: number) => { x: number; y: number }) => {
      e.preventDefault();
      const pos = screenToCanvas(e.clientX, e.clientY);

      setDragState({
        isDragging: true,
        cardId,
        handIndex,
        currentX: pos.x,
        currentY: pos.y,
        startX: pos.x,
        startY: pos.y,
      });
    },
    []
  );

