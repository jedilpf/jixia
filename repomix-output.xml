import { useScale } from '@/hooks/useScale';
import { useBattleState } from '@/hooks/useBattleState';
import { useDragAndDrop } from '@/hooks/useDragAndDrop';
import { LAYOUT } from '@/config/layoutSpec';
import { getHandCardPositions } from '@/utils/layoutUtils';

const CANVAS_WIDTH = 1920;
const CANVAS_HEIGHT = 1080;

export function BattleLayout() {
  const { scaleInfo, screenToCanvas, canvasToScreen } = useScale(
    CANVAS_WIDTH,
    CANVAS_HEIGHT
  );
  const {
    game,
    selection,
    handleStartGame,
    handleEndTurn,
    handleSlotClick,
    handleHeroClick,
  } = useBattleState();
  const { dragState, handleDragStart, handleDragMove, handleDragEnd } =
    useDragAndDrop();

  useEffect(() => {
    const handlePointerMove = (e: PointerEvent) => {
      if (dragState.isDragging) {
        handleDragMove(e, screenToCanvas);
      }
    };
    window.addEventListener('pointermove', handlePointerMove);
    return () => window.removeEventListener('pointermove', handlePointerMove);
  }, [dragState.isDragging, handleDragMove, screenToCanvas]);

