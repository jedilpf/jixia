                                fontFamily: '"STKaiti", serif',
                                fontSize: '16px', letterSpacing: '4px',
                                cursor: 'pointer',
                                boxShadow: '0 4px 12px rgba(0,0,0,0.35), inset 0 1px rgba(255,255,255,0.08)',
                                transition: 'all 0.15s',
