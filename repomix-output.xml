}

export interface CardInstanceBase {
    instanceId: string;
    cardId: string;
    name: string;
    type: string;
}

export type AnyInstance = 
    | CharacterInstance 
    | GearInstance 
    | FieldInstance 
    | Hero;

export function createDefaultBuffs(): Buffs {
    return {
        huchi: 0,
        qishi: 0,
        qingming: 0,
        bilei: 0,
        xueshi: 0,
    };
}

export function createDefaultDebuffs(): Debuffs {
    return {
        huaiyi: 0,
        chenmo: 0,
    };
}

export function createDefaultHero(): Hero {
    return {
        hp: 30,
        maxHp: 30,
