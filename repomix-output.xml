    const minionCard = card as MinionCard;
    const minion: MinionInstance = {
      instanceId: `${card.id}_${Date.now()}_${Math.random().toString(36).substr(2, 5)}`,
      cardId: card.id,
      name: card.name,
      atk: minionCard.atk,
      hp: minionCard.hp,
      maxHp: minionCard.hp,
      canAttack: true,
      hasAttacked: false,
      isExhausted: !minionCard.hasCharge,
      hasTaunt: minionCard.hasTaunt,
      rarity: minionCard.rarity,
    };

