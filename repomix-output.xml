export function getEmptySlotCenterOut(board: (MinionInstance | null)[]): number {
  const priority = [3, 2, 4, 1, 5, 0, 6];
  for (const slotIndex of priority) {
    if (board[slotIndex] === null) {
      return slotIndex;
    }
  }
  return -1;
}

