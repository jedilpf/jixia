            }} />

            {/* ── 层1：主背景渐变叠加 ── */}
            <div style={{
                position: 'absolute', inset: 0,
                background: `
          radial-gradient(ellipse 80% 50% at 50% 110%, rgba(232,93,4,0.12) 0%, transparent 60%),
