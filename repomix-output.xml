                <BronzeGear x={W - 100 * scale} y={H * 0.0} size={200 * scale} speed={32} opacity={0.09} reverse />
                <BronzeGear x={W * 0.08} y={H * 0.55} size={120 * scale} speed={20} opacity={0.1} reverse />
