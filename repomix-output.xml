          className="w-4 h-4 text-[#8a7a6a] group-hover:text-[#c9b896] transition-colors"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            strokeLinecap="round"
            strokeLinejoin="round"
            strokeWidth={2}
