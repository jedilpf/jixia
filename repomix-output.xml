// 功能：法力水晶条组件

import type { PlayerState } from '@/types/game';

interface ManaBarProps {
  player: PlayerState;
  isEnemy?: boolean;
  scale: number;
}

export function ManaBar({ player, isEnemy = false, scale }: ManaBarProps) {
  const { mana, maxMana } = player;
  const crystals = Array.from({ length: 10 }, (_, i) => ({
    index: i,
    filled: i < mana,
    available: i < maxMana,
  }));

  return (
    <div
      style={{
        display: 'flex',
        alignItems: 'center',
        gap: `${4 * scale}px`,
        padding: `${4 * scale}px ${8 * scale}px`,
        background: 'rgba(0,0,0,0.6)',
        borderRadius: `${8 * scale}px`,
        border: `${1 * scale}px solid rgba(139,115,85,0.3)',
      }}
    >
      {crystals.map((crystal) => (
        <div
          key={crystal.index}
          style={{
            width: `${20 * scale}px`,
            height: `${20 * scale}px`,
            borderRadius: '50%',
            background: crystal.filled
              ? 'radial-gradient(circle at 35% 30%, #60a5fa 0%, #1d4ed8 60%, #0f2060 100%)'
              : crystal.available
                ? 'radial-gradient(circle at 35% 30%, #1e3a5f 0%, #0f1f3a 60%, #050a15 100%)'
                : 'rgba(30,30,30,0.5)',
            boxShadow: crystal.filled
              ? '0 0 8px rgba(96,165,250,0.6)'
              : 'none',
            border: `${1 * scale}px solid ${crystal.filled 
              ? 'rgba(147,197,253,0.5)' : 'rgba(50,50,50,0.5)'}`,
            transition: 'all 0.3s ease',
          }}
        />
      ))}
      <div style={{
        color: '#60a5fa',
        fontWeight: 700,
        fontSize: `${14 * scale}px`,
        marginLeft: `${4 * scale}px`,
        textShadow: '0 0 8px rgba(96,165,250,0.5)',
      }}>
        {mana}/{maxMana}
      </div>
    </div>
  );
}

