          : 'border-[#d0b98a]/50 bg-[#f7edde]/50'
      } ${isSelectable || onDropCard ? 'cursor-pointer' : 'cursor-default'}`}
    >
      <span className="mb-2 text-xs font-bold text-[#5c4631]">
        {SEAT_ALIAS[seat]}
        {isTarget && <span className="ml-1 text-[#b4823f]">✓</span>}
