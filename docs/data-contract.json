{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "BattleV2 runtime data contract (frontend/backend/AI shared reference)",
  "lastUpdated": "2026-04-01",
  "system": "BattleV2 (DebateBattle)",
  "DebateCard": {
    "type": "object",
    "description": "Single card definition used in battle runtime",
    "required": [
      "id",
      "name",
      "type",
      "cost",
      "effectKind",
      "effectValue"
    ],
    "properties": {
      "id": {
        "type": "string"
      },
      "name": {
        "type": "string"
      },
      "type": {
        "type": "string",
        "description": "Localized card type (e.g. 立论/策术/反诘/门客/玄章)"
      },
      "cost": {
        "type": "integer",
        "minimum": 0
      },
      "effectKind": {
        "type": "string",
        "enum": [
          "damage",
          "shield",
          "draw",
          "zhengli",
          "shixu",
          "summon_front",
          "summon_back"
        ]
      },
      "effectValue": {
        "type": "integer"
      },
      "power": {
        "type": "integer"
      },
      "hp": {
        "type": "integer"
      },
      "art": {
        "type": "string"
      },
      "prologue": {
        "type": "string"
      },
      "description": {
        "type": "string"
      },
      "lanePreference": {
        "type": "string",
        "enum": [
          "left",
          "center",
          "right"
        ]
      },
      "faction": {
        "type": "string"
      },
      "factionCore": {
        "type": "boolean"
      },
      "guestEligible": {
        "type": "boolean"
      },
      "signatureSlot": {
        "type": "integer"
      },
      "sceneBias": {
        "type": "string",
        "enum": [
          "left",
          "center",
          "right",
          "all"
        ]
      },
      "tags": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    }
  },
  "Resources": {
    "type": "object",
    "required": [
      "xinZheng",
      "lingShi",
      "maxLingShi",
      "huYin",
      "zhengLi",
      "shiXu",
      "wenMai",
      "jiBian",
      "daShi",
      "chou"
    ],
    "properties": {
      "xinZheng": {
        "type": "integer"
      },
      "lingShi": {
        "type": "integer"
      },
      "maxLingShi": {
        "type": "integer"
      },
      "huYin": {
        "type": "integer"
      },
      "zhengLi": {
        "type": "integer"
      },
      "shiXu": {
        "type": "integer"
      },
      "wenMai": {
        "type": "integer"
      },
      "jiBian": {
        "type": "integer"
      },
      "daShi": {
        "type": "integer",
        "minimum": 0,
        "maximum": 8
      },
      "chou": {
        "type": "integer",
        "minimum": 0,
        "maximum": 1
      }
    }
  },
  "SeatUnit": {
    "type": "object",
    "required": [
      "id",
      "name",
      "power",
      "hp",
      "maxHp"
    ],
    "properties": {
      "id": {
        "type": "string"
      },
      "name": {
        "type": "string"
      },
      "power": {
        "type": "integer"
      },
      "hp": {
        "type": "integer"
      },
      "maxHp": {
        "type": "integer"
      }
    }
  },
  "SeatState": {
    "type": "object",
    "required": [
      "front",
      "back"
    ],
    "properties": {
      "front": {
        "type": [
          "object",
          "null"
        ]
      },
      "back": {
        "type": [
          "object",
          "null"
        ]
      }
    }
  },
  "TurnPlan": {
    "type": "object",
    "required": [
      "mainCardId",
      "responseCardId",
      "secretCardId",
      "writingCardId",
      "mainTargetSeat",
      "secretTargetSeat",
      "usedLingShi",
      "lockedPublic",
      "lockedSecret"
    ],
    "properties": {
      "mainCardId": {
        "type": [
          "string",
          "null"
        ]
      },
      "responseCardId": {
        "type": [
          "string",
          "null"
        ]
      },
      "secretCardId": {
        "type": [
          "string",
          "null"
        ]
      },
      "writingCardId": {
        "type": [
          "string",
          "null"
        ]
      },
      "mainTargetSeat": {
        "type": "string",
        "enum": [
          "xian_sheng",
          "zhu_bian",
          "yu_lun"
        ]
      },
      "secretTargetSeat": {
        "type": "string",
        "enum": [
          "xian_sheng",
          "zhu_bian",
          "yu_lun"
        ]
      },
      "usedLingShi": {
        "type": "integer"
      },
      "lockedPublic": {
        "type": "boolean"
      },
      "lockedSecret": {
        "type": "boolean"
      }
    }
  },
  "SubmitAction": {
    "type": [
      "object",
      "null"
    ],
    "properties": {
      "type": {
        "type": "string",
        "enum": [
          "play_card",
          "pass"
        ]
      },
      "cardId": {
        "type": [
          "string",
          "null"
        ]
      },
      "zone": {
        "type": [
          "string",
          "null"
        ],
        "enum": [
          "main",
          "side",
          "prep",
          null
        ]
      },
      "useToken": {
        "type": "boolean"
      }
    }
  },
  "BattlePlayer": {
    "type": "object",
    "required": [
      "side",
      "name",
      "resources",
      "deck",
      "hand",
      "discard",
      "writings",
      "seats",
      "plan",
      "gold",
      "submitAction"
    ],
    "properties": {
      "side": {
        "type": "string",
        "enum": [
          "player",
          "enemy"
        ]
      },
      "name": {
        "type": "string"
      },
      "resources": {
        "$ref": "#/definitions/Resources"
      },
      "deck": {
        "type": "array",
        "items": {
          "$ref": "#/DebateCard"
        }
      },
      "hand": {
        "type": "array",
        "items": {
          "$ref": "#/DebateCard"
        }
      },
      "discard": {
        "type": "array",
        "items": {
          "$ref": "#/DebateCard"
        }
      },
      "writings": {
        "type": "array",
        "items": {
          "$ref": "#/DebateCard"
        }
      },
      "seats": {
        "type": "object",
        "required": [
          "xian_sheng",
          "zhu_bian",
          "yu_lun"
        ],
        "properties": {
          "xian_sheng": {
            "$ref": "#/definitions/SeatState"
          },
          "zhu_bian": {
            "$ref": "#/definitions/SeatState"
          },
          "yu_lun": {
            "$ref": "#/definitions/SeatState"
          }
        }
      },
      "plan": {
        "$ref": "#/TurnPlan"
      },
      "loadout": {
        "type": "object"
      },
      "gold": {
        "type": "integer"
      },
      "submitAction": {
        "$ref": "#/SubmitAction"
      }
    }
  },
  "BattleLogEntry": {
    "type": "object",
    "required": [
      "id",
      "round",
      "text"
    ],
    "properties": {
      "id": {
        "type": "string"
      },
      "round": {
        "type": "integer",
        "minimum": 1
      },
      "text": {
        "type": "string"
      },
      "timestamp": {
        "type": "integer"
      }
    }
  },
  "DebateBattleState": {
    "type": "object",
    "required": [
      "round",
      "maxRounds",
      "phase",
      "secondsLeft",
      "activeTopicId",
      "activeTopic",
      "topicSelectionPending",
      "topicSelectionRound",
      "topicSelectionSecondsLeft",
      "topicOptions",
      "arenaId",
      "arenaName",
      "player",
      "enemy",
      "logs",
      "resolveFeed",
      "internalAudit",
      "winner"
    ],
    "properties": {
      "round": {
        "type": "integer",
        "minimum": 1
      },
      "maxRounds": {
        "type": "integer",
        "minimum": 1
      },
      "phase": {
        "type": "string",
        "enum": [
          "ming_bian",
          "an_mou",
          "reveal",
          "resolve",
          "finished"
        ]
      },
      "secondsLeft": {
        "type": "integer",
        "minimum": 0
      },
      "activeTopicId": {
        "type": [
          "string",
          "null"
        ]
      },
      "activeTopic": {
        "type": "string"
      },
      "topicSelectionPending": {
        "type": "boolean"
      },
      "topicSelectionRound": {
        "type": "integer",
        "minimum": 0
      },
      "topicSelectionSecondsLeft": {
        "type": [
          "integer",
          "null"
        ],
        "minimum": 0
      },
      "topicOptions": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "arenaId": {
        "type": "string",
        "enum": [
          "jixia",
          "huode",
          "cangshu",
          "guanxing"
        ]
      },
      "arenaName": {
        "type": "string"
      },
      "player": {
        "$ref": "#/BattlePlayer"
      },
      "enemy": {
        "$ref": "#/BattlePlayer"
      },
      "logs": {
        "type": "array",
        "items": {
          "$ref": "#/definitions/BattleLogEntry"
        }
      },
      "resolveFeed": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "internalAudit": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "winner": {
        "type": [
          "string",
          "null"
        ],
        "enum": [
          "player",
          "enemy",
          "draw",
          null
        ]
      }
    }
  },
  "definitions": {
    "Resources": {
      "type": "object",
      "properties": {
        "xinZheng": {
          "type": "integer"
        },
        "lingShi": {
          "type": "integer"
        },
        "maxLingShi": {
          "type": "integer"
        },
        "huYin": {
          "type": "integer"
        },
        "zhengLi": {
          "type": "integer"
        },
        "shiXu": {
          "type": "integer"
        },
        "wenMai": {
          "type": "integer"
        },
        "jiBian": {
          "type": "integer"
        },
        "daShi": {
          "type": "integer"
        },
        "chou": {
          "type": "integer"
        }
      }
    },
    "SeatState": {
      "type": "object",
      "properties": {
        "front": {
          "type": [
            "object",
            "null"
          ]
        },
        "back": {
          "type": [
            "object",
            "null"
          ]
        }
      }
    },
    "SeatUnit": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "power": {
          "type": "integer"
        },
        "hp": {
          "type": "integer"
        },
        "maxHp": {
          "type": "integer"
        }
      }
    },
    "BattleLogEntry": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "round": {
          "type": "integer"
        },
        "text": {
          "type": "string"
        },
        "timestamp": {
          "type": "integer"
        }
      }
    }
  }
}
