{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jixia.local/schemas/ai-task.schema.json",
  "title": "AI Task Packet",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "task_id",
    "goal",
    "constraints",
    "deliverables",
    "allowed_write_paths",
    "acceptance_commands"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "constraints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "deliverables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "allowed_write_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "acceptance_commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
